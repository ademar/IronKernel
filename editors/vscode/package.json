{
  "name": "ironkernel",
  "displayName": "IronKernel",
  "description": "Language support and a real-runtime playground for IronKernel.",
  "version": "0.1.0",
  "publisher": "ironkernel-lang",
  "icon": "icon.png",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/ironkernel-lang/IronKernel.git",
    "directory": "editors/vscode"
  },
  "homepage": "https://ironkernel.org",
  "engines": {
    "vscode": "^1.125.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "kernel",
    "lisp",
    "fexpr",
    "vau"
  ],
  "main": "./dist/extension.js",
  "extensionKind": [
    "workspace"
  ],
  "activationEvents": [
    "onLanguage:ironkernel",
    "onCommand:ironkernel.runFile",
    "onCommand:ironkernel.compileFile",
    "onCommand:ironkernel.runProject",
    "onCommand:ironkernel.buildProject",
    "onCommand:ironkernel.openPlayground"
  ],
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": "limited",
      "restrictedConfigurations": [
        "ironkernel.executablePath",
        "ironkernel.projectPath",
        "ironkernel.ikprojPath",
        "ironkernel.runArgs",
        "ironkernel.profile"
      ]
    },
    "virtualWorkspaces": false
  },
  "contributes": {
    "languages": [
      {
        "id": "ironkernel",
        "aliases": [
          "IronKernel",
          "Kernel"
        ],
        "extensions": [
          ".ikr"
        ],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "xml",
        "extensions": [
          ".ikproj"
        ],
        "aliases": [
          "IronKernel Project"
        ]
      }
    ],
    "grammars": [
      {
        "language": "ironkernel",
        "scopeName": "source.ironkernel",
        "path": "./syntaxes/ironkernel.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "ironkernel",
        "path": "./snippets/ironkernel.code-snippets"
      }
    ],
    "commands": [
      {
        "command": "ironkernel.runFile",
        "title": "IronKernel: Run Current File",
        "category": "IronKernel"
      },
      {
        "command": "ironkernel.compileFile",
        "title": "IronKernel: Compile Current File to IKC",
        "category": "IronKernel"
      },
      {
        "command": "ironkernel.runProject",
        "title": "IronKernel: Run Project",
        "category": "IronKernel"
      },
      {
        "command": "ironkernel.buildProject",
        "title": "IronKernel: Build Project",
        "category": "IronKernel"
      },
      {
        "command": "ironkernel.openPlayground",
        "title": "IronKernel: Open Playground",
        "category": "IronKernel"
      },
      {
        "command": "ironkernel.showOutput",
        "title": "IronKernel: Show Output",
        "category": "IronKernel"
      }
    ],
    "menus": {
      "editor/title/run": [
        {
          "command": "ironkernel.runFile",
          "when": "editorLangId == ironkernel && isWorkspaceTrusted",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "command": "ironkernel.runProject",
          "when": "resourceExtname == .ikproj && isWorkspaceTrusted",
          "group": "ironkernel@1"
        },
        {
          "command": "ironkernel.buildProject",
          "when": "resourceExtname == .ikproj && isWorkspaceTrusted",
          "group": "ironkernel@2"
        }
      ],
      "editor/context": [
        {
          "command": "ironkernel.runProject",
          "when": "resourceExtname == .ikproj && isWorkspaceTrusted",
          "group": "ironkernel@1"
        },
        {
          "command": "ironkernel.buildProject",
          "when": "resourceExtname == .ikproj && isWorkspaceTrusted",
          "group": "ironkernel@2"
        }
      ]
    },
    "configurationDefaults": {
      "files.associations": {
        "*.ikproj": "xml"
      },
      "editor.tokenColorCustomizations": {
        "textMateRules": [
          {
            "name": "IronKernel operatives",
            "scope": "keyword.control.operative.ironkernel",
            "settings": {
              "foreground": "#f0a060"
            }
          },
          {
            "name": "IronKernel applicatives",
            "scope": "support.function.applicative.ironkernel",
            "settings": {
              "foreground": "#6ec9b8"
            }
          }
        ]
      }
    },
    "configuration": {
      "title": "IronKernel",
      "properties": {
        "ironkernel.executablePath": {
          "type": "string",
          "default": "",
          "description": "Absolute path to the IronKernel executable. Leave empty to use this repository's .NET project or PATH."
        },
        "ironkernel.projectPath": {
          "type": "string",
          "default": "IronKernel/IronKernel.fsproj",
          "description": "Workspace-relative .NET project used by dotnet run when developing IronKernel."
        },
        "ironkernel.ikprojPath": {
          "type": "string",
          "default": "",
          "description": "Optional path to an .ikproj for Run/Build Project. Absolute, or workspace-relative. When empty, the nearest .ikproj is discovered."
        },
        "ironkernel.runArgs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Arguments passed to Run Current File or Run Project."
        },
        "ironkernel.profile": {
          "type": "string",
          "enum": [
            "minimal",
            "safe",
            "unrestricted"
          ],
          "default": "unrestricted",
          "description": "Capability profile used for scripts, packages, and playground execution."
        },
        "ironkernel.playground.timeoutMs": {
          "type": "number",
          "default": 10000,
          "minimum": 1000,
          "maximum": 120000,
          "description": "Maximum playground execution time in milliseconds."
        },
        "ironkernel.maxOutputBytes": {
          "type": "number",
          "default": 1048576,
          "minimum": 4096,
          "maximum": 16777216,
          "description": "Maximum stdout or stderr retained for one execution."
        }
      }
    },
    "problemPatterns": [
      {
        "name": "ironkernel",
        "regexp": "^(?:Script error|Compile error|Package error|Project error|Startup error):\\s+(.+):(\\d+):(\\d+):\\s+(.*)$",
        "file": 1,
        "line": 2,
        "column": 3,
        "message": 4
      }
    ],
    "problemMatchers": [
      {
        "name": "ironkernel",
        "owner": "ironkernel",
        "fileLocation": [
          "absolute"
        ],
        "pattern": "$ironkernel"
      }
    ]
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "package": "npm run build && vsce package --no-dependencies",
    "vscode:prepublish": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/vscode": "^1.125.0",
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.28.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10",
    "vscode-oniguruma": "^2.0.1",
    "vscode-textmate": "^9.3.2"
  }
}
