{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "IronKernel",
  "scopeName": "source.ironkernel",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#constants" },
    { "include": "#numbers" },
    { "include": "#operatives" },
    { "include": "#applicatives" },
    { "include": "#keywords" },
    { "include": "#quote" },
    { "include": "#punctuation" },
    { "include": "#symbols" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.semicolon.ironkernel",
          "begin": ";",
          "end": "$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.ironkernel",
          "begin": "\"",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.string.begin.ironkernel" }
          },
          "end": "\"",
          "endCaptures": {
            "0": { "name": "punctuation.definition.string.end.ironkernel" }
          },
          "patterns": [
            {
              "name": "constant.character.escape.ironkernel",
              "match": "\\\\[\\\\nrt\"]"
            }
          ]
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.ironkernel",
          "match": "(?<![:!#$%|*+\\-./<=>?@^_~\\p{L}\\p{N}])#(?:t|f|inert)(?![:!#$%|*+\\-./<=>?@^_~\\p{L}\\p{N}])"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.ironkernel",
          "match": "(?<![:!#$%|*+\\-./<=>?@^_~\\p{L}\\p{N}])-?(?:0[xX][0-9a-fA-F]+|(?:[0-9]+(?:\\.[0-9]*)?|\\.[0-9]+)(?:[eE][+-]?[0-9]+)?)(?:L)?(?![:!#$%|*+\\-./<=>?@^_~\\p{L}\\p{N}])"
        }
      ]
    },
    "operatives": {
      "patterns": [
        {
          "name": "keyword.control.operative.ironkernel",
          "match": "(?<![:!#$%|*+\\-./<=>?@^_~\\p{L}\\p{N}])(?:bindings->environment|get-current-environment|remote-eval|provide!|import!|letrec\\*|clr-alias|clr-open|clr-type|contract|sequence|define|lambda|letrec|prompt|quote|reset|and\\?|cond|defn|lazy|let\\*|or\\?|set!|time|\\.get|\\.set|new|vau|ϝ|λ|if|let|\\.)(?![:!#$%|*+\\-./<=>?@^_~\\p{L}\\p{N}])"
        }
      ]
    },
    "applicatives": {
      "patterns": [
        {
          "name": "support.function.applicative.ironkernel",
          "match": "(?<![:!#$%|*+\\-./<=>?@^_~\\p{L}\\p{N}])(?:make-encapsulation-type|close-output-port|close-input-port|open-output-file|open-input-file|make-prompt-tag|make-environment|read-contents|contract-of|environment\\?|make-vector|vector-set!|vector-ref|await-task|task-delay|clr-opens|call/cc|memoize|promise\\?|for-each|compose|let/cc|printf|vector\\?|zero\\?|null\\?|pair\\?|list\\*|length|apply|begin|force|print|shift|show|load|wrap|eval|unwrap|read-all|write|read|car|cdr|cons|eq\\?|eqv\\?|vector|list|map|any\\?|zip|not\\?|caar|cadr|cdar|cddr|perform|resume|<=|\\+|\\-|\\*|\\/|<|>)(?![:!#$%|*+\\-./<=>?@^_~\\p{L}\\p{N}])"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "constant.other.keyword.ironkernel",
          "match": ":[!#$%|*+\\-./:<=>?@^_~\\p{L}\\p{N}]+"
        }
      ]
    },
    "quote": {
      "patterns": [
        {
          "name": "punctuation.definition.quote.ironkernel",
          "match": "'"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.section.parens.ironkernel",
          "match": "[()]"
        },
        {
          "name": "punctuation.section.brackets.ironkernel",
          "match": "[\\[\\]]"
        },
        {
          "name": "keyword.operator.improper-list.ironkernel",
          "match": "&"
        }
      ]
    },
    "symbols": {
      "patterns": [
        {
          "name": "variable.other.symbol.ironkernel",
          "match": "[:!#$%|*+\\-./<=>?@^_~\\p{L}][:!#$%|*+\\-./<=>?@^_~\\p{L}\\p{N}]*"
        }
      ]
    }
  }
}
