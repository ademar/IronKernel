{
  "comments": {
    "lineComment": ";"
  },
  "brackets": [
    ["(", ")"],
    ["[", "]"]
  ],
  "autoClosingPairs": [
    { "open": "(", "close": ")" },
    { "open": "[", "close": "]" },
    { "open": "\"", "close": "\"", "notIn": ["string", "comment"] }
  ],
  "surroundingPairs": [
    ["(", ")"],
    ["[", "]"],
    ["\"", "\""]
  ],
  "indentationRules": {
    "increaseIndentPattern": "^.*[\\(\\[]\\s*(?:;.*)?$",
    "decreaseIndentPattern": "^\\s*[\\)\\]]"
  },
  "wordPattern": "([:!#$%|*+\\-./<=>?@^_~A-Za-zλϝ][:!#$%|*+\\-./<=>?@^_~A-Za-z0-9λϝ]*)"
}
